# Conversease production environment template
#
# Copy to `.env.production` on the server and replace every placeholder.
# Never commit `.env.production`.

# Compose database bootstrap
POSTGRES_USER=conversease
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=conversease_db

# Runtime
RELEASE_VERSION=2026.06.04
APP_ENV=production
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
PUBLIC_APP_URL=https://app.example.com
API_BASE_URL=https://api.example.com
CORS_ORIGINS_RAW=https://app.example.com

# App database/cache
# Use the Docker service host `postgres` inside Compose.
# URL-encode POSTGRES_PASSWORD here if it contains reserved URL characters.
DATABASE_URL=postgresql+psycopg://conversease:replace-with-url-encoded-postgres-password@postgres:5432/conversease_db
REDIS_URL=redis://redis:6379/0

# Host backup connection. Production compose binds Postgres only to 127.0.0.1.
BACKUP_DATABASE_URL=postgresql+psycopg://conversease:replace-with-url-encoded-postgres-password@127.0.0.1:5432/conversease_db
BACKUP_DIR=/opt/conversease/backups
BACKUP_RETENTION_DAYS=14
AUTO_DELETE_BACKUPS=false

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/api/auth/google/callback
ADMIN_EMAILS_RAW=owner@example.com

# Web build/runtime
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api

# Billing provider
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
PAYMENT_ADMIN_EMAIL=denahku.team@gmail.com
PAYMENT_ADMIN_API_KEY=replace-with-at-least-24-random-characters
MANUAL_TRANSFER_BANK_NAME="Bank Jago"
MANUAL_TRANSFER_ACCOUNT_NUMBER="5001 6527 8492"
MANUAL_TRANSFER_ACCOUNT_HOLDER="Fikri Firdaus"
MANUAL_TRANSFER_UNIQUE_CODE_MIN=101
MANUAL_TRANSFER_UNIQUE_CODE_MAX=999
MANUAL_TRANSFER_EXPIRE_HOURS=12

# Email provider
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM="Conversease <no-reply@mail.example.com>"
EMAIL_REPLY_TO=support@example.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=30
ADMIN_RATE_LIMIT_REQUESTS=120

# AI/STT/TTS providers. Optional for controlled manual-feedback beta.
LLM_DEFAULT_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_CHAT_MODEL=MiniMaxAI/MiniMax-M2.7
ASSEMBLYAI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_BASE_URL=https://api.minimax.io
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=English_expressive_narrator
MINIMAX_TTS_LANGUAGE_BOOST=English
MINIMAX_TTS_TIMEOUT_SECONDS=90

# Audio storage for admin CMS generation
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_PUBLIC_BASE_URL=

# API process
API_WORKERS=2
