# Conversease environment template
#
# Copy to `.env.local` for local development.
# Never commit real secrets.

# Runtime
RELEASE_VERSION=dev
APP_ENV=development
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS_RAW=http://localhost:3000

# Database and cache
# Local Docker overrides DATABASE_URL and REDIS_URL to internal service hosts.
# Omit DATABASE_URL only when you intentionally want the app's SQLite fallback.
DATABASE_URL=postgresql+psycopg://conversease:conversease@localhost:5432/conversease_db
REDIS_URL=redis://localhost:6379/0

# Auth
# Production requires at least 32 characters and must not use the development value.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional. Defaults to API_BASE_URL + /api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Comma-separated emails that should be promoted to admin on login/session check.
ADMIN_EMAILS_RAW=

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Billing provider
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
PAYMENT_ADMIN_EMAIL=denahku.team@gmail.com
PAYMENT_ADMIN_API_KEY=replace-with-at-least-24-random-characters
MANUAL_TRANSFER_BANK_NAME="Bank Jago"
MANUAL_TRANSFER_ACCOUNT_NUMBER="5001 6527 8492"
MANUAL_TRANSFER_ACCOUNT_HOLDER="Fikri Firdaus"
MANUAL_TRANSFER_UNIQUE_CODE_MIN=101
MANUAL_TRANSFER_UNIQUE_CODE_MAX=999
MANUAL_TRANSFER_EXPIRE_HOURS=12

# Email provider
RESEND_API_KEY=
EMAIL_FROM="Conversease <no-reply@mail.conversease.com>"
EMAIL_REPLY_TO=support@conversease.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=30
ADMIN_RATE_LIMIT_REQUESTS=120

# AI/STT/TTS providers
LLM_DEFAULT_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_API_BASE_URL=https://api.together.xyz
TOGETHER_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_PARTNER_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_TIMEOUT_SECONDS=30
# Speech-to-text: "whisper_together" (default, low latency) or "assemblyai"
STT_PROVIDER=whisper_together
WHISPER_MODEL=openai/whisper-large-v3
WHISPER_LANGUAGE=en
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_API_BASE_URL=https://api.assemblyai.com
ASSEMBLYAI_SPEECH_MODELS_RAW=universal-3-pro,universal-2
ASSEMBLYAI_TRANSCRIPT_TIMEOUT_SECONDS=60
ASSEMBLYAI_POLL_INTERVAL_SECONDS=1.5
ASSEMBLYAI_MAX_AUDIO_BYTES=15728640
MINIMAX_API_KEY=
MINIMAX_API_BASE_URL=https://api.minimax.io
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=English_expressive_narrator
MINIMAX_TTS_LANGUAGE_BOOST=English
MINIMAX_TTS_TIMEOUT_SECONDS=90

# Audio storage for admin CMS generation
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_PUBLIC_BASE_URL=
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600
