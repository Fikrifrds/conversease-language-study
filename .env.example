# Conversease environment template
#
# Copy to `.env` for local Docker or configure these variables in your deployment platform.
# Never commit real secrets.

# Runtime
RELEASE_VERSION=dev
APP_ENV=development
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS_RAW=http://localhost:3000

# Database and cache
# Docker and production should use PostgreSQL.
# Omit DATABASE_URL only when you intentionally want the app's SQLite fallback.
DATABASE_URL=postgresql+psycopg://conversease:conversease@postgres:5432/conversease_db
REDIS_URL=redis://redis:6379/0

# Auth
# Production requires at least 32 characters and must not use the development value.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional. Defaults to API_BASE_URL + /api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Billing provider
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
PAYMENT_ADMIN_EMAIL=denahku.team@gmail.com
PAYMENT_ADMIN_API_KEY=replace-with-at-least-24-random-characters
MANUAL_TRANSFER_BANK_NAME=Bank Jago
MANUAL_TRANSFER_ACCOUNT_NUMBER=5001 6527 8492
MANUAL_TRANSFER_ACCOUNT_HOLDER=Fikri Firdaus
MANUAL_TRANSFER_UNIQUE_CODE_MIN=101
MANUAL_TRANSFER_UNIQUE_CODE_MAX=999
MANUAL_TRANSFER_EXPIRE_HOURS=12

# Email provider
RESEND_API_KEY=
EMAIL_FROM=Conversease <no-reply@mail.conversease.com>
EMAIL_REPLY_TO=support@conversease.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=30
ADMIN_RATE_LIMIT_REQUESTS=120

# AI/STT/TTS providers
LLM_DEFAULT_PROVIDER=together
TOGETHER_API_KEY=
ASSEMBLYAI_API_KEY=
MINIMAX_API_KEY=
